generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Region {
  id        String    @id @default(cuid())
  name      String
  stations  Station[]
  createdAt DateTime  @default(now())
}

model Station {
  id        String      @id @default(cuid())
  name      String
  regionId  String
  region    Region      @relation(fields: [regionId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]
  dutyVehicles Vehicle[] @relation("DutyStation")
  personnel Personnel[]
  createdAt DateTime    @default(now())
}

model Vehicle {
  id              String    @id @default(cuid())
  plate           String    @unique
  brand           String
  model           String
  year            Int
  stationId       String
  station         Station   @relation(fields: [stationId], references: [id])
  status          String    @default("Aktif")
  dutyStationId   String?
  dutyStation     Station?  @relation("DutyStation", fields: [dutyStationId], references: [id])
  materials       String    @default("[]")
  insuranceExpiry DateTime?
  kaskoExpiry     DateTime?
  muayeneExpiry   DateTime?
  notes           String?
  faults          Fault[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Fault {
  id          String    @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type        String
  description String
  location    String?
  serviceId   String?
  service     Service?  @relation(fields: [serviceId], references: [id])
  serviceName String?
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("Devam Ediyor")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Personnel {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  title     String
  stationId String
  station   Station  @relation(fields: [stationId], references: [id])
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
}

model Service {
  id      String  @id @default(cuid())
  name    String
  address String?
  phone   String?
  notes   String?
  faults  Fault[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
